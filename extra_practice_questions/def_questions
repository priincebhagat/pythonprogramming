# Word Frequency Counter

def word_frequency(sentence):
    words = sentence.split()
    counts = {}

    for word in words:
        if word in counts:
            counts[word] += 1
        else :
            counts[word] = 1
    return counts

print (word_frequency("i love cat cat love food food is good"))

# Count Vowels
# Write a function count_vowels(word) that takes a single word (a string) and returns the number of vowels (a, e, i, o, u) in it.
def count_vowels(word):
    vowels = "aeiouAEIOU"
    count = 0
    for char in word:
        if char in vowels:
            count += 1
    return count

print(count_vowels("Prince Bhagat"))

# Find the Largest Number
# Write a function find_largest(numbers) that takes a list of numbers and returns the largest one — without using Python's built-in max()
def find_largest(numbers):
    largest = numbers[0]

    for num in numbers:
        if num > largest:
            largest = num

    return largest 

print(find_largest([25, 33, 45, 49]))        

# Count Even Numbers
# Write a function count_evens(numbers) that takes a list of numbers and returns how many of them are even.

def count_evens(numbers):
    even_number = 0

    for even in numbers:
        if even % 2 == 0:
            even_number += 1

    return even_number

print(count_evens([1, 2, 3, 4, 5, 6]))

# Sum of a List
# Write a function sum_list(numbers) that takes a list of numbers and returns the total sum of all of them — without using Python's built-in sum() function.

def sum_list(numbers):
    calc_list = 0

    for nums in numbers:
        calc_list += nums

    return calc_list

print(sum_list([25, 18, 17, 20]))

# Average of a List
# Write a function average(numbers) that takes a list of numbers and returns their average

def average(numbers):
    total = 0
    count = 0

    for num in numbers:
        total += num
        count = count + 1
    return total / count

print(average([18, 25, 17])) 

# Count Occurrences of a Specific Value
# Write a function count_occurrences(numbers, target) that takes a list of numbers and a target number, and returns how many times target appears in the list.

def count_occurrences(number, target):
    count = 0

    for num in number:
        if num == target:
            count = count + 1

    return count
    
print(count_occurrences([3, 7, 3, 3, 9, 7], 7))

# Check if a Number is Prime

def is_prime(n):
    if n < 2:
        return False

    for i in range(2, n):
        if n % i == 0:
            return False

    return True

print(is_prime(13))

# Reverse a List
# Write a function reverse_list(numbers) that takes a list of numbers and returns a new list with the elements in reverse order — without using Python's built-in .reverse() method or [::-1] slicing.

def reverse_list(numbers):
    reversed_numbers = []
    
    for num in numbers:
        reversed_numbers.insert(0, num)
    
    return reversed_numbers
print(reverse_list([1,2,3,4,5]))
