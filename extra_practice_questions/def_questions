# Word Frequency Counter

def word_frequency(sentence):
    words = sentence.split()
    counts = {}

    for word in words:
        if word in counts:
            counts[word] += 1
        else :
            counts[word] = 1
    return counts

print (word_frequency("i love cat cat love food food is good"))

# Count Vowels
# Write a function count_vowels(word) that takes a single word (a string) and returns the number of vowels (a, e, i, o, u) in it.
def count_vowels(word):
    vowels = "aeiouAEIOU"
    count = 0
    for char in word:
        if char in vowels:
            count += 1
    return count

print(count_vowels("Prince Bhagat"))

# Find the Largest Number
# Write a function find_largest(numbers) that takes a list of numbers and returns the largest one — without using Python's built-in max()
def find_largest(numbers):
    largest = numbers[0]

    for num in numbers:
        if num > largest:
            largest = num

    return largest 

print(find_largest([15, 3, 42, 8, 23]))        

# Count Even Numbers
# Write a function count_evens(numbers) that takes a list of numbers and returns how many of them are even.

def count_evens(numbers):
    even_number = 0

    for even in numbers:
        if even % 2 == 0:
            even_number += 1

    return even_number

print(count_evens([1, 2, 3, 4, 5, 6]))

# Sum of a List
# Write a function sum_list(numbers) that takes a list of numbers and returns the total sum of all of them — without using Python's built-in sum() function.

def sum_list(numbers):
    calc_list = 0

    for nums in numbers:
        calc_list += nums

    return calc_list

print(sum_list([25, 18, 17, 20]))

