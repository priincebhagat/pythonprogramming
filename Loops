# While loop
#while loop is used to execute a block of code repeatedly as long as a given condition is true.
count = 1
while count <= 3:
    print("count : ", count)
    count += 1

#practice question 1
#print numbers from 100 to 1 using while loop
i = 100
while i >= 1:
    print(i)
    i -= 1 

#practice question 2
#print multiplication table of a number using while loop
i = 1
n = int(input("enter a number : "))
while i <= 10:
    print(n*i)
    i += 1

#practice question 3
#print elements of a list using while loop
num = [3,1,5,2,6,4,8,7]
idx = 0
while idx < len(num):
    print(num[idx])
    idx += 1

#practice question 4
#search an element in a list using while loop
num = (3,1,5,2,6,4,8,7)
x = 7
i = 0
while i < len(num):
    if (num[i] == x):
        print("found")
    i += 1

#For loop
#for loop is used to iterate over a sequence (like a list, tuple, string)

num = [1, 5, 8, 3, 6, 2, 4, 7]
for val in num:
    print(val)

#practice question
#search an element in a tuple using for loop
num = (1, 5, 8, 3, 6, 2, 4, 7)
x = 9
idx = 0
for val in num:
    if val == x:
        print("found the element at index : ", idx)
        break
    idx += 1
else:
    print("not found")
